{
   "name": "pg-typescraft-root",
   "version": "1.0.0",
   "description": "",
   "packageManager": "pnpm@10.29.3+sha512.498e1fb4cca5aa06c1dcf2611e6fafc50972ffe7189998c409e90de74566444298ffe43e6cd2acdc775ba1aa7cc5e092a8b7054c811ba8c5770f84693d33d2dc",
   "type": "module",
   "author": "Adrian Topala",
   "license": "Apache-2.0",
   "repository": "https://github.com/atopala/valnor",
   "engines": {
      "node": ">=22.0.0",
      "pnpm": ">=10.17.0"
   },
   "scripts": {
      "preinstall": "npx only-allow pnpm",
      "db-migrate": "run-s 'db-migrate:*'",
      "db-migrate:postgres": "env-cmd --no-override -x -r ./env-dev.json -e postgres postgrator --username \\$POSTGRES_USER --password \\$POSTGRES_PASSWORD --config @db-postgres/migrate-local.json",
      "db-migrate:sqlite3": "postgrator --config @db-sqlite3/migrate-local.json",
      "db-migrate:mssql": "env-cmd --no-override -x -r ./env-dev.json -e mssql postgrator --username \\$MSSQL_USER --password \\$MSSQL_PASSWORD --config @db-mssql/migrate-local.json",
      "clean:build": "pnpm -r --parallel exec rimraf dist deploy tsconfig.tsbuildinfo",
      "clean:1-lock-file": "pnpm exec rimraf pnpm-lock.yaml",
      "clean:2-dependencies-r": "pnpm -r --parallel exec rimraf node_modules",
      "clean:3-dependencies-w": "pnpm exec rimraf node_modules",
      "clean-all": "run-s 'clean:*'",
      "lint": "pnpm exec eslint . --ext .ts,.tsx,.js,.jsx",
      "format": "prettier --write \"./packages/**/*.{js,ts,jsx,tsx,json,md,yml,yaml}\"",
      "build": "run-s 'build:*'",
      "build:1-core": "pnpm --filter './packages/*' run build",
      "build:4-install": "pnpm install --frozen-lockfile",
      "build:5-rest": "pnpm -r run build",
      "codegen": "run-s 'codegen:*' | pino-pretty",
      "codegen:2-generate-postgres": "env-cmd --no-override -x -r ./env-dev.json -e db node ./packages/valnor/cli.mjs generate --plugin valnor-postgres --schema one_sql --pascalCaseTables --camelCaseColumns --host \\$POSTGRES_HOST --port \\$POSTGRES_PORT --database \\$POSTGRES_DATABASE --user \\$POSTGRES_USER --password \\$POSTGRES_PASSWORD --outDir 'packages/valnor/src/core/__tests__/models' | pino-pretty",
      "codegen:3-generate-sqlite3": "node ./packages/valnor/cli.mjs generate --plugin valnor-sqlite3 --schema one_sql --pascalCaseTables --camelCaseColumns --uri '@db-sqlite3/valnor-test.sqlite' --outDir 'packages/valnor-sqlite3/src/__tests__/codegen' | pino-pretty",
      "codegen:4-generate-mssql": "env-cmd --no-override -x -r ./env-dev.json -e db node ./packages/valnor/cli.mjs generate --plugin valnor-mssql --schema one_sql --pascalCaseTables --camelCaseColumns --host \\$MSSQL_HOST --port \\$MSSQL_PORT --database \\$MSSQL_DATABASE --user \\$MSSQL_USER --password \\$MSSQL_PASSWORD --outDir 'packages/valnor-mssql/src/__tests__/codegen' | pino-pretty",
      "pretest": "run-s 'codegen'",
      "test": "vitest --coverage run"
   },
   "devDependencies": {
      "@eslint/js": "^9.17.0",
      "@types/node": "20.19.0",
      "@vitest/coverage-v8": "^4.0.18",
      "add": "^2.0.6",
      "copyfiles": "^2.4.1",
      "deepmerge": "^4.3.1",
      "env-cmd": "^10.1.0",
      "eslint": "^9.17.0",
      "eslint-config-prettier": "^9.1.0",
      "eslint-plugin-import": "^2.31.0",
      "eslint-plugin-prettier": "^5.2.1",
      "eslint-plugin-simple-import-sort": "^12.1.1",
      "eslint-plugin-unused-imports": "^4.1.4",
      "npm-run-all": "^4.1.5",
      "pg": "^8.16.0",
      "pino-pretty": "^13.1.1",
      "postgrator-cli": "^9.1.0",
      "prettier": "^3.4.2",
      "replace-in-file": "^8.3.0",
      "rimraf": "^6.0.1",
      "sqlite3": "^5.1.7",
      "typescript": "^5.5.3",
      "typescript-eslint": "^8.18.2",
      "valnor": "workspace:^",
      "vite": "^7.3.1",
      "vite-node": "^2.1.8",
      "vitest": "^4.0.18"
   },
   "pnpm": {
      "overrides": {
         "semver": ">=7.5.2",
         "esbuild": ">=0.25.0"
      }
   },
   "private": true
}

{
   "name": "pg-typescraft-root",
   "version": "1.0.0",
   "description": "",
   "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215",
   "type": "module",
   "author": "Adrian Topala",
   "license": "Apache-2.0",
   "repository": "https://github.com/vexnor-dev/vexnor",
   "engines": {
      "node": ">=22.21.1",
      "pnpm": ">=11.0.0"
   },
   "scripts": {
      "preinstall": "npx only-allow pnpm",
      "db-migrate": "run-s 'db-migrate:*'",
      "db-migrate:postgres": "env-cmd --no-override -x -r ./env-dev.json -e postgres postgrator --username \\$POSTGRES_USER --password \\$POSTGRES_PASSWORD --config @db-postgres/migrate-local.json",
      "db-migrate:sqlite3": "postgrator --config @db-sqlite3/migrate-local.json",
      "db-migrate:mssql": "env-cmd --no-override -x -r ./env-dev.json -e mssql postgrator --username \\$MSSQL_USER --password \\$MSSQL_PASSWORD --config @db-mssql/migrate-local.json",
      "clean:1-build": "pnpm -r --parallel exec rimraf dist deploy tsconfig.tsbuildinfo",
      "clean:1-lock-file": "pnpm exec rimraf pnpm-lock.yaml",
      "clean:1-dependencies-r": "pnpm -r --parallel exec rimraf node_modules",
      "clean:1-dependencies-w": "pnpm exec rimraf node_modules",
      "clean:1-test": "pnpm -r --parallel exec rimraf dist deploy tsconfig.tsbuildinfo",
      "clean:11-testing-r": "pnpm exec rimraf coverage",
      "clean:11-testing-w": "pnpm -r --parallel exec rimraf coverage",
      "clean-all": "run-s 'clean:1-*'",
      "lint": "pnpm exec eslint . --ext .ts,.tsx,.js,.jsx",
      "format": "prettier --write \"./packages/**/*.{js,ts,jsx,tsx,json,md,yml,yaml}\"",
      "build": "run-s 'build:*'",
      "build:1-core": "pnpm --filter './packages/*' run build",
      "build:4-install": "pnpm install --frozen-lockfile",
      "build:5-rest": "pnpm -r run build",
      "test": "vitest --coverage run"
   },
   "devDependencies": {
      "@eslint/js": "^9.17.0",
      "@types/node": "20.19.0",
      "@vitest/coverage-v8": "^4.1.5",
      "add": "^2.0.6",
      "copyfiles": "^2.4.1",
      "deepmerge": "^4.3.1",
      "env-cmd": "^10.1.0",
      "eslint": "^9.17.0",
      "eslint-config-prettier": "^9.1.0",
      "eslint-plugin-import": "^2.31.0",
      "eslint-plugin-prettier": "^5.2.1",
      "eslint-plugin-simple-import-sort": "^12.1.1",
      "eslint-plugin-unused-imports": "^4.1.4",
      "npm-run-all": "^4.1.5",
      "pg": "^8.16.0",
      "pino-pretty": "^13.1.1",
      "postgrator-cli": "^9.1.0",
      "prettier": "^3.4.2",
      "replace-in-file": "^8.3.0",
      "rimraf": "^6.0.1",
      "sqlite3": "^5.1.7",
      "typescript": "5.9.3",
      "typescript-eslint": "^8.18.2",
      "vexnor": "workspace:^",
      "vite": "^8.0.10",
      "vite-node": "^2.1.8",
      "vitest": "^4.1.5"
   },
   "private": true
}

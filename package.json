{
  "name": "pg-typescraft-root",
  "version": "1.0.0",
  "description": "",
  "packageManager": "pnpm@10.18.2+sha512.9fb969fa749b3ade6035e0f109f0b8a60b5d08a1a87fdf72e337da90dcc93336e2280ca4e44f2358a649b83c17959e9993e777c2080879f3801e6f0d999ad3dd",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.17.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "db-migrate": "run-s 'db-migrate:*'",
    "db-migrate:postgres": "env-cmd --no-override -x -r ./env-dev.json -e db postgrator --username \\$POSTGRES_USER --password \\$POSTGRES_PASSWORD --config @db-postgres/migrate-local.json",
    "db-migrate:sqlite3": "postgrator --config @db-sqlite3/migrate-local.json",
    "db-migrate:mssql": "env-cmd --no-override -x -r ./env-dev.json -e db postgrator --username \\$MSSQL_USER --password \\$MSSQL_PASSWORD --config @db-mssql/migrate-local.json",
    "clean:build": "pnpm -r --parallel exec rimraf dist deploy tsconfig.tsbuildinfo",
    "clean:1-lock-file": "pnpm exec rimraf pnpm-lock.yaml",
    "clean:2-dependencies-r": "pnpm -r --parallel exec rimraf node_modules",
    "clean:3-dependencies-w": "pnpm exec rimraf node_modules",
    "clean-all": "run-s 'clean:*'",
    "lint": "pnpm exec eslint . --ext .ts,.tsx,.js,.jsx",
    "format": "prettier --write \"./packages/**/*.{js,ts,jsx,tsx,json,md,yml,yaml}\"",
    "build": "run-s 'build:*'",
    "build:1-core": "pnpm --filter './packages/valnor' run build",
    "build:2-plugins": "pnpm --filter './packages/valnor-sqlite3' --filter './packages/valnor-postgres' run build",
    "build:3-main": "pnpm --filter './packages/valnor' run build",
    "build:4-install": "pnpm install --frozen-lockfile",
    "build:5-rest": "pnpm --filter '!./packages/valnor' --filter '!./packages/valnor' --filter '!./packages/valnor-sqlite3' --filter '!./packages/valnor-postgres' run build",
    "codegen": "run-s 'codegen:*' | pino-pretty",
    "codegen:1-generate-core": "env-cmd --no-override -x -r ./env-dev.json -e db node ./packages/valnor/cli.mjs generate --plugin valnor-postgres --schema one_sql --pascalCaseTables --camelCaseColumns --host \\$POSTGRES_HOST --port \\$POSTGRES_PORT --database \\$POSTGRES_DATABASE --user \\$POSTGRES_USER --password \\$POSTGRES_PASSWORD --outDir 'packages/valnor/src/core/__tests__/codegen' | pino-pretty",
    "codegen:2-generate-postgres": "env-cmd --no-override -x -r ./env-dev.json -e db node ./packages/valnor/cli.mjs generate --plugin valnor-postgres --schema one_sql --pascalCaseTables --camelCaseColumns --host \\$POSTGRES_HOST --port \\$POSTGRES_PORT --database \\$POSTGRES_DATABASE --user \\$POSTGRES_USER --password \\$POSTGRES_PASSWORD --outDir 'packages/valnor-postgres/src/__tests__/codegen' | pino-pretty",
    "codegen:3-generate-sqlite3": "node ./packages/valnor/cli.mjs generate --plugin valnor-sqlite3 --schema one_sql --pascalCaseTables --camelCaseColumns --uri '@db-sqlite3/valnor-test.sqlite' --outDir 'packages/valnor-sqlite3/src/__tests__/codegen' | pino-pretty",
    "codegen:4-generate-mssql": "env-cmd --no-override -x -r ./env-dev.json -e db node ./packages/valnor/cli.mjs generate --plugin valnor-mssql --schema one_sql --pascalCaseTables --camelCaseColumns --host \\$MSSQL_HOST --port \\$MSSQL_PORT --database \\$MSSQL_DATABASE --user \\$MSSQL_USER --password \\$MSSQL_PASSWORD --outDir 'packages/valnor-mssql/src/__tests__/codegen' | pino-pretty",
    "pretest": "run-s 'codegen'",
    "test": "run-s 'test:*'",
    "test:1-vitest": "vitest run",
    "test:2-testing-e2e": "pnpm --filter './packages/testing-e2e' run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "20.19.0",
    "@vitest/coverage-v8": "^3.2.4",
    "add": "^2.0.6",
    "copyfiles": "^2.4.1",
    "env-cmd": "^10.1.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "npm-run-all": "^4.1.5",
    "pg": "^8.16.0",
    "pino-pretty": "^13.1.1",
    "postgrator-cli": "^9.0.1",
    "prettier": "^3.4.2",
    "replace-in-file": "^8.3.0",
    "rimraf": "^6.0.1",
    "sqlite3": "^5.1.7",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.18.2",
    "vite": "^7.1.5",
    "vite-node": "^2.1.8",
    "vitest": "^3.2.4"
  },
  "private": true
}

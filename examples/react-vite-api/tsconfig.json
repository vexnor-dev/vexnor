{
   "compilerOptions": {
      "strict": true,
      "skipLibCheck": true,
      "target": "ES2022",
      "module": "ESNext",
      "moduleResolution": "bundler",
      "jsx": "react-jsx",
      "lib": [
         "ES2022",
         "DOM",
         "DOM.Iterable"
      ],
      "noEmit": true,
      "resolveJsonModule": true,
      "noUnusedLocals": true,
      "noUnusedParameters": true,
      "paths": {
         "#/*": [
            "./client/src/*"
         ],
         "#shared/*": [
            "./shared/*"
         ],
         "#shared/codegen/postgres/*": [
            "./shared/codegen/postgres/*"
         ],
         "#shared/codegen/mssql/*": [
            "./shared/codegen/mssql/*"
         ]
      }
   },
   "include": [
      "client"
   ]
}

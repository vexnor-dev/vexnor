{
   "compilerOptions": {
      "target": "ES2022",
      "lib": ["ES2022", "DOM", "DOM.Iterable"],
      "module": "ESNext",
      "moduleResolution": "bundler",
      "strict": true,
      "jsx": "react-jsx",
      "esModuleInterop": true,
      "skipLibCheck": true,
      "noEmit": true,
      "paths": {
         "#shared/*": ["./shared/*"],
         "#/*": ["./src/*"]
      }
   },
   "include": ["src", "shared"]
}

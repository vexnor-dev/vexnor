{
   "compilerOptions": {
      "target": "ES2022",
      "module": "Node16",
      "moduleResolution": "Node16",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "outDir": "./dist",
      "rootDir": ".",
      "paths": {
         "#models/postgres/*": ["./models/postgres/*"],
         "#models/mssql/*": ["./models/mssql/*"],
         "#models/sqlite3/*": ["./models/sqlite3/*"]
      }
   },
   "include": ["*.ts", "queries/**/*.ts"]
}

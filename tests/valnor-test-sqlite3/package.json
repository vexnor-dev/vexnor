{
   "name": "@valnor/valnor-test-sqlite3",
   "version": "1.0.0-beta.1",
   "description": "Integration tests for valnor",
   "type": "module",
   "author": "Adrian Topala",
   "license": "Apache-2.0",
   "scripts": {
      "precodegen": "pnpm run -r --filter='valnor' --filter='valnor-sqlite3' build",
      "codegen": "env-cmd --no-override -x -r ../../env-dev.json -e sqlite3 node ../../packages/valnor/cli.mjs codegen --plugin valnor-sqlite3 --schema main --pascalCaseTables --camelCaseColumns --uri \\$SQLITE_PATH --outDir './src/codegen' | pino-pretty",
      "test": "vitest --coverage run",
      "test:watch": "vitest --watch",
      "test:run": "vitest run",
      "build": "tsc -b"
   },
   "dependencies": {
      "@sinclair/typebox": "^0.34.41",
      "better-sqlite3": "^12.4.1",
      "valnor": "workspace:*",
      "valnor-sqlite3": "workspace:*"
   },
   "devDependencies": {
      "@types/better-sqlite3": "^7.6.13",
      "@valnor/test-utils": "workspace:*",
      "@vitest/coverage-v8": "^3.2.4",
      "vite-tsconfig-paths": "^5.1.4",
      "vitest": "^3.2.4"
   }
}

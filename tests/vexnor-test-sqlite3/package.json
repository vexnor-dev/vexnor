{
   "name": "@vexnor/vexnor-test-sqlite3",
   "version": "1.0.0-beta.1",
   "description": "Integration tests for vexnor",
   "type": "module",
   "author": "Adrian Topala",
   "license": "Apache-2.0",
   "scripts": {
      "precodegen": "pnpm run -r --filter='vexnor' --filter='vexnor-sqlite3' --filter='vexnor-drizzle' --filter='vexnor-prisma' --filter='vexnor-typeorm'  build",
      "codegen:vexnor": "env-cmd --no-override -x -r ../../env-dev.json -e sqlite3 node ../../packages/vexnor/cli.mjs codegen --plugin vexnor-sqlite3 --schema main --pascalCaseTables --camelCaseColumns --uri \\$SQLITE_PATH --omit migration_vexnor --outDir './src/codegen' | pino-pretty",
      "codegen:prisma": "pnpm exec prisma generate --schema prisma/schema.prisma",
      "prebuild": "run-s 'codegen:*'",
      "pretest": "run-s 'codegen:*'",
      "test": "vitest --coverage run",
      "test:watch": "vitest --watch",
      "test:run": "vitest run",
      "build": "tsc -b"
   },
   "dependencies": {
      "@sinclair/typebox": "^0.34.41",
      "better-sqlite3": "^12.4.1",
      "vexnor": "workspace:*",
      "vexnor-drizzle": "workspace:*",
      "vexnor-prisma": "workspace:*",
      "vexnor-sqlite3": "workspace:*",
      "vexnor-typeorm": "workspace:*"
   },
   "devDependencies": {
      "@prisma/client": "^6.19.3",
      "@prisma/internals": "^6.9.0",
      "@types/better-sqlite3": "^7.6.13",
      "@vitest/coverage-v8": "^4.1.5",
      "drizzle-orm": "^1.0.0-beta.20",
      "prisma": "^6.19.3",
      "reflect-metadata": "^0.2.2",
      "typeorm": "^0.3.24",
      "vite-tsconfig-paths": "^6.1.1",
      "vitest": "^4.1.5"
   }
}

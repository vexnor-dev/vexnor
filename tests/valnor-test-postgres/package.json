{
   "name": "@valnor/valnor-test-postgres",
   "version": "1.0.0-beta.1",
   "description": "Integration tests for valnor",
   "type": "module",
   "author": "Adrian Topala",
   "license": "Apache-2.0",
   "scripts": {
      "precodegen": "pnpm run -r --filter='valnor' --filter='valnor-postgres' build",
      "codegen": "env-cmd --no-override -x -r ../../env-dev.json -e postgres node ../../packages/valnor/cli.mjs codegen --plugin valnor-postgres --schema valnor_test --pascalCaseTables --camelCaseColumns --host \\$POSTGRES_HOST --port \\$POSTGRES_PORT --database \\$POSTGRES_DATABASE --user \\$POSTGRES_USER --password \\$POSTGRES_PASSWORD --outDir './src/codegen' | pino-pretty",
      "test": "vitest --coverage run",
      "test:watch": "vitest --watch",
      "test:run": "vitest run",
      "build": "tsc -b"
   },
   "dependencies": {
      "@sinclair/typebox": "^0.34.41",
      "pg": "^8.16.3",
      "valnor": "workspace:*",
      "valnor-drizzle": "workspace:*",
      "valnor-postgres": "workspace:*",
      "valnor-typeorm": "workspace:*"
   },
   "devDependencies": {
      "@types/pg": "^8.15.5",
      "@vitest/coverage-v8": "^4.0.18",
      "drizzle-orm": "^1.0.0-beta.20",
      "reflect-metadata": "^0.2.2",
      "typeorm": "^0.3.24",
      "env-cmd": "^10.1.0",
      "vite-node": "^2.1.8",
      "vite-tsconfig-paths": "^6.1.1",
      "vitest": "^4.0.18"
   }
}

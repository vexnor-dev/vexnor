{
   "name": "@vexnor/vexnor-test-mssql",
   "version": "1.0.0-beta.1",
   "description": "Integration tests for vexnor",
   "type": "module",
   "author": "Adrian Topala",
   "license": "Apache-2.0",
   "scripts": {
      "precodegen": "pnpm run -r --filter='vexnor' run build",
      "codegen:vexnor": "env-cmd --no-override -x -r ../../env-dev.json -e mssql node ../../packages/vexnor/cli.mjs codegen --plugin vexnor-mssql --schema vexnor_dev --pascalCaseTables --camelCaseColumns --host \\$MSSQL_HOST --port \\$MSSQL_PORT --database \\$MSSQL_DATABASE --user \\$MSSQL_USER --password \\$MSSQL_PASSWORD --outDir './src/codegen' | pino-pretty",
      "codegen:prisma": "pnpm exec prisma generate --schema prisma/schema.prisma --config prisma/prisma.config.ts",
      "codegen": "run-s 'codegen:*'",
      "build:dependencies": "pnpm --filter='vexnor-mssql' --filter='vexnor-drizzle' --filter='vexnor-prisma' --filter='vexnor-typeorm' run build",
      "prebuild": "run-s 'build:dependencies' 'codegen:*'",
      "build": "tsc -b",
      "pretest": "run-s 'codegen:*'",
      "test": "vitest --coverage run",
      "test:watch": "vitest --watch",
      "test:run": "vitest run",
      "test1": "env-cmd --no-override -x -r ../../env-dev.json -e mssql vite-node src/test.ts | pino-pretty"
   },
   "dependencies": {
      "@sinclair/typebox": "^0.34.41",
      "mssql": "^12.5.2",
      "vexnor": "workspace:*",
      "vexnor-drizzle": "workspace:*",
      "vexnor-mssql": "workspace:*",
      "vexnor-prisma": "workspace:*",
      "vexnor-sequelize": "workspace:*",
      "vexnor-typeorm": "workspace:*"
   },
   "devDependencies": {
      "@prisma/adapter-mssql": "^7.8.0",
      "@prisma/client": "^7.8.0",
      "@types/mssql": "^12.3.0",
      "@vitest/coverage-v8": "^4.1.5",
      "drizzle-orm": "^1.0.0-beta.20",
      "prisma": "^7.8.0",
      "reflect-metadata": "^0.2.2",
      "sequelize": "^6.37.7",
      "typeorm": "^0.3.24",
      "vite-tsconfig-paths": "^6.1.1",
      "vitest": "^4.1.7"
   }
}

{
   "name": "default",
   "description": "Full-stack development agent for vexnor-aws-vercel monorepo (Next.js + @vexnor/core)",
   "tools": [
      "read",
      "write",
      "shell",
      "grep",
      "glob",
      "code",
      "use_aws",
      "web_fetch",
      "web_search",
      "knowledge",
      "subagent",
      "todo_list"
   ],
   "allowedTools": [
      "read",
      "write",
      "shell",
      "grep",
      "glob",
      "code",
      "use_aws",
      "knowledge",
      "todo_list",
      "web_search",
      "web_fetch",
      "subagent"
   ],
   "toolsSettings": {
      "write": {
         "allowedPaths": [
            "packages/**",
            "plugins/**",
            "orms/**",
            "tests/**",
            "examples/**",
            "docs/**",
            ".github/**",
            ".kiro/**",
            "*.json",
            "*.ts",
            "*.mjs",
            "*.yml",
            "*.yaml"
         ],
         "deniedPaths": [
            "node_modules/**",
            "**/node_modules/**",
            "**/dist/**",
            "**/*.tsbuildinfo",
            "pnpm-lock.yaml"
         ]
      },
      "shell": {
         "allowedCommands": [
            "pnpm.*",
            "npm.*",
            "node.*",
            "npx.*",
            "tsc.*",
            "tsc-alias.*",
            "vitest.*",
            "next.*",
            "git.*",
            "gh.*",
            "curl.*",
            "ls.*",
            "cat.*",
            "find.*",
            "grep.*",
            "sed.*",
            "echo.*",
            "mkdir.*",
            "rm (?!-rf /).*",
            "which.*",
            "cd.*",
            "head.*",
            "tail.*",
            "wc.*",
            "sort.*",
            "jq.*",
            "python3.*",
            "xargs.*",
            "basename.*",
            "dirname.*",
            "uniq.*",
            "diff.*",
            "pwd.*",
            "sleep.*"
         ],
         "deniedCommands": [
            "rm -rf /.*",
            "sudo.*"
         ],
         "autoAllowReadonly": true,
         "denyByDefault": false
      },
      "web_fetch": {
         "trusted": [
            ".*localhost.*",
            ".*github\\.com.*",
            ".*raw\\.githubusercontent\\.com.*",
            ".*docs\\.aws\\.amazon\\.com.*",
            ".*npmjs\\.com.*",
            ".*nextjs\\.org.*",
            ".*vitejs\\.dev.*",
            ".*devpost\\.com.*"
         ],
         "blocked": []
      }
   },
   "resources": [
      "file://README.md",
      "file://package.json",
      "file://pnpm-workspace.yaml",
      "file://tsconfig.json"
   ]
}

{
   "extends": "../../tsconfig.json",
   "compilerOptions": {
      "outDir": "./dist",
      "rootDir": "./src",
      "declaration": true,
      "declarationMap": true,
      "composite": true,
      "paths": {
         "#/*": [
            "./src/*"
         ]
      },
      "stripInternal": true
   },
   "include": [
      "src/**/*"
   ],
   "exclude": [
      "dist",
      "node_modules"
   ]
}

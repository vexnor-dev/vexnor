{
  "name": "@vexnor/sequelize",
  "version": "1.0.0-beta.1",
  "description": "Sequelize adaptor for vexnor — convert Sequelize models/views to vexnor runtime tables",
  "type": "module",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "imports": {
    "#/*": "./dist/*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "keywords": [
    "vexnor",
    "sequelize",
    "adaptor",
    "sql"
  ],
  "author": "Adrian Topala",
  "license": "Apache-2.0",
  "repository": "https://github.com/vexnor-dev/vexnor",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "build": "tsc -b",
    "postbuild": "tsc-alias",
    "pretest": "run-s 'build'",
    "test": "vitest --coverage run",
    "test:watch": "vitest --watch",
    "test:run": "vitest run"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@vexnor/core": "workspace:^"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "npm-run-all": "^4.1.5",
    "sequelize": "^6.37.7",
    "sqlite3": "^5.1.7",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "sequelize": ">=6.0.0"
  },
  "changelog": "https://github.com/vexnor-dev/vexnor/releases"
}

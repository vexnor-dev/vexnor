{
   "extends": "../../tsconfig.json",
   "compilerOptions": {
      "outDir": "./dist",
      "rootDir": "./src",
      "declaration": true,
      "declarationMap": true,
      "composite": true,
      "experimentalDecorators": true,
      "emitDecoratorMetadata": true,
      "paths": {
         "#/*": ["./src/*"]
      }
   },
   "include": ["src/**/*"],
   "exclude": ["dist", "node_modules"],
   "references": [
      {
         "path": "../../packages/vexnor"
      }
   ]
}

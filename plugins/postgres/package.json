{
  "name": "@vexnor/postgres",
  "version": "1.0.0-beta.1",
  "description": "PostgreSQL plugin for vexnor supporting pg and postgres.js drivers",
  "type": "module",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "imports": {
    "#src/*": "./dist/*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.browser.js",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "keywords": [
    "vexnor-plugin",
    "@vexnor/postgres",
    "vexnor",
    "postgresql",
    "postgres",
    "pg",
    "postgres.js",
    "sql",
    "plugin"
  ],
  "author": "Adrian Topala",
  "license": "Apache-2.0",
  "repository": "https://github.com/vexnor-dev/vexnor",
  "sideEffects": [
    "./dist/index.js",
    "./dist/index.browser.js",
    "./dist/@vexnor/postgres.js",
    "./dist/postgres-augment.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "build": "tsc -b",
    "pretest": "run-s 'build'",
    "test": "vitest --coverage run",
    "test:watch": "vitest --watch",
    "test:run": "vitest run",
    "vexnor:exec": "pnpm vexnor exec run --config ../../vexnor.config.ts --query-config find-enums.vexnor.ts findEnums | pino-pretty"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@vexnor/core": "workspace:^"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "@vitest/coverage-v8": "^4.1.5",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "pg": "^8.16.3"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  },
  "changelog": "https://github.com/vexnor-dev/vexnor/releases"
}

{
   "name": "valnor-mssql",
   "version": "1.0.0-beta.1",
   "description": "MS SQL Server plugin for valnor",
   "author": "Adrian Topala",
   "license": "Apache-2.0",
   "repository": "https://github.com/atopala/valnor",
   "type": "module",
   "module": "dist/index.js",
   "main": "dist/index.js",
   "types": "dist/index.d.ts",
   "exports": {
      ".": {
         "types": "./dist/index.d.ts",
         "import": "./dist/index.js",
         "require": "./dist/index.js"
      }
   },
   "keywords": [
      "valnor-plugin",
      "valnor-mssql",
      "valnor",
      "mssql",
      "sql",
      "plugin"
   ],
   "publishConfig": {
      "access": "public"
   },
   "scripts": {
      "build": "tsc -b",
      "pretest": "run-s 'build'",
      "test": "vitest --coverage run",
      "test:watch": "vitest --watch",
      "test:run": "vitest run"
   },
   "files": [
      "dist",
      "package.json",
      "README.md"
   ],
   "dependencies": {
      "valnor": "workspace:^"
   },
   "devDependencies": {
      "@types/mssql": "^9.1.5",
      "@vitest/coverage-v8": "^3.2.4",
      "npm-run-all": "^4.1.5",
      "typescript": "^5.9.3",
      "vite-tsconfig-paths": "^5.1.4",
      "vitest": "^3.2.4"
   },
   "peerDependencies": {
      "mssql": "^11.0.1"
   },
   "peerDependenciesMeta": {
      "mssql": {
         "optional": true
      }
   }
}

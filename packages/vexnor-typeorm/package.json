{
   "name": "vexnor-typeorm",
   "version": "1.0.0-beta.1",
   "description": "TypeORM adaptor for vexnor — convert TypeORM entities to vexnor runtime tables",
   "type": "module",
   "module": "dist/index.js",
   "main": "dist/index.js",
   "types": "dist/index.d.ts",
   "imports": {
      "#/*": "./dist/*"
   },
   "exports": {
      ".": {
         "types": "./dist/index.d.ts",
         "import": "./dist/index.js",
         "require": "./dist/index.js"
      }
   },
   "keywords": [
      "vexnor",
      "typeorm",
      "adaptor",
      "sql"
   ],
   "author": "Adrian Topala",
   "license": "Apache-2.0",
   "repository": "https://github.com/vexnor-dev/vexnor",
   "sideEffects": false,
   "publishConfig": {
      "access": "public"
   },
   "scripts": {
      "build": "tsc -b",
      "postbuild": "tsc-alias",
      "pretest": "run-s 'build'",
      "test": "vitest --coverage run",
      "test:watch": "vitest --watch",
      "test:run": "vitest run"
   },
   "files": [
      "dist",
      "package.json",
      "README.md"
   ],
   "dependencies": {
      "vexnor": "workspace:^"
   },
   "devDependencies": {
      "@types/better-sqlite3": "^7.6.13",
      "@vitest/coverage-v8": "^4.1.8",
      "better-sqlite3": "^12.10.0",
      "npm-run-all": "^4.1.5",
      "reflect-metadata": "^0.2.2",
      "tsc-alias": "^1.8.17",
      "typeorm": "^0.3.30",
      "typescript": "^5.9.3",
      "vite-tsconfig-paths": "^6.1.1",
      "vitest": "^4.1.8"
   },
   "peerDependencies": {
      "reflect-metadata": ">=0.1.0",
      "typeorm": ">=0.3.0"
   }
}

{
   "name": "valnor-sqlite3",
   "version": "1.0.0-beta.1",
   "description": "SQLite3 plugin for valnor using better-sqlite3",
   "type": "module",
   "module": "dist/index.js",
   "main": "dist/index.js",
   "types": "dist/index.d.ts",
   "exports": {
      ".": {
         "types": "./dist/index.d.ts",
         "import": "./dist/index.js",
         "require": "./dist/index.js"
      }
   },
   "keywords": [
      "valnor",
      "sqlite3",
      "better-sqlite3",
      "sql",
      "plugin"
   ],
   "author": "Adrian Topala",
   "license": "Apache-2.0",
   "repository": "https://github.com/atopala/valnor",
   "publishConfig": {
      "access": "public"
   },
   "scripts": {
      "codegen": "env-cmd --no-override -x -r ../../env-dev.json -e db valnor generate --plugin valnor-sqlite3 --schema one_sql --pascalCaseTables --camelCaseColumns --uri \\$SQLITE_PATH --outDir 'src/__tests__/codegen' | pino-pretty",
      "build": "tsc -b",
      "pretest": "run-s 'build'",
      "test": "vitest --coverage run",
      "test:watch": "vitest --watch"
   },
   "files": [
      "dist",
      "package.json",
      "README.md"
   ],
   "dependencies": {
      "valnor": "workspace:*"
   },
   "devDependencies": {
      "@types/better-sqlite3": "^7.6.13",
      "typescript": "^5.5.3",
      "vitest": "^3.2.4"
   },
   "peerDependencies": {
      "better-sqlite3": "^12.2.0"
   }
}
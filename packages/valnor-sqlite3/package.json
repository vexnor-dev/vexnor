{
   "name": "valnor-sqlite3",
   "version": "1.0.0-beta.1",
   "description": "SQLite3 plugin for valnor using better-sqlite3",
   "type": "module",
   "module": "dist/index.js",
   "main": "dist/index.js",
   "types": "dist/index.d.ts",
   "exports": {
      ".": {
         "types": "./dist/index.d.ts",
         "import": "./dist/index.js",
         "require": "./dist/index.js"
      }
   },
   "keywords": [
      "valnor",
      "sqlite3",
      "better-sqlite3",
      "sql",
      "plugin"
   ],
   "author": "Adrian Topala",
   "license": "Apache-2.0",
   "repository": "https://github.com/atopala/valnor",
   "publishConfig": {
      "access": "public"
   },
   "scripts": {
      "codegen": "valnor generate --plugin valnor-sqlite3 --schema one_sql --pascalCaseTables --camelCaseColumns --uri '../../@db-sqlite3/valnor-test.sqlite' --outDir 'src/__tests__/codegen' | pino-pretty",
      "build": "run-s 'build:*'",
      "build:1-tsc": "tsc -b",
      "build:2-alias": "tsc-alias",
      "pretest": "run-s 'build'",
      "test": "vitest --coverage run",
      "test:watch": "vitest --watch"
   },
   "files": [
      "dist",
      "package.json"
   ],
   "dependencies": {
      "valnor": "workspace:*"
   },
   "devDependencies": {
      "@types/better-sqlite3": "^7.6.13",
      "@vitest/coverage-v8": "^4.0.18",
      "npm-run-all": "^4.1.5",
      "tsc-alias": "^1.8.16",
      "typescript": "^5.9.3",
      "vite-tsconfig-paths": "^6.1.1",
      "vitest": "^4.0.18"
   },
   "peerDependencies": {
      "better-sqlite3": "^12.2.0"
   }
}

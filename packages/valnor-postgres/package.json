{
   "name": "valnor-postgres",
   "version": "1.0.0-beta.1",
   "description": "PostgreSQL plugin for valnor supporting pg and postgres.js drivers",
   "type": "module",
   "module": "dist/index.js",
   "main": "dist/index.js",
   "types": "dist/index.d.ts",
   "exports": {
      ".": {
         "types": "./dist/index.d.ts",
         "import": "./dist/index.js",
         "require": "./dist/index.js"
      }
   },
   "keywords": [
      "valnor-plugin",
      "valnor-postgres",
      "valnor",
      "postgresql",
      "postgres",
      "pg",
      "postgres.js",
      "sql",
      "plugin"
   ],
   "author": "Adrian Topala",
   "license": "Apache-2.0",
   "repository": "https://github.com/atopala/valnor",
   "publishConfig": {
      "access": "public"
   },
   "scripts": {
      "build": "tsc -b",
      "pretest": "run-s 'build'",
      "test": "vitest --coverage run",
      "test:watch": "vitest --watch",
      "test:run": "vitest run",
      "valnor:exec": "pnpm valnor exec run --config ../../valnor.config.ts --query-config find-enums.valnor.ts findEnums | pino-pretty"
   },
   "files": [
      "dist",
      "package.json",
      "README.md"
   ],
   "dependencies": {
      "valnor": "workspace:^"
   },
   "devDependencies": {
      "@types/pg": "^8.15.5",
      "@vitest/coverage-v8": "^4.0.18",
      "npm-run-all": "^4.1.5",
      "typescript": "^5.9.3",
      "vite-tsconfig-paths": "^6.1.1",
      "vitest": "^4.0.18"
   },
   "peerDependencies": {
      "pg": "^8.16.3"
   },
   "peerDependenciesMeta": {
      "pg": {
         "optional": true
      }
   }
}

{
   "name": "vexnor-mssql",
   "version": "1.0.0-beta.1",
   "description": "MS SQL Server plugin for vexnor",
   "author": "Adrian Topala",
   "license": "Apache-2.0",
   "repository": "https://github.com/vexnor-dev/vexnor",
   "type": "module",
   "module": "dist/index.js",
   "main": "dist/index.js",
   "types": "dist/index.d.ts",
   "exports": {
      ".": {
         "types": "./dist/index.d.ts",
         "browser": "./dist/index.browser.js",
         "import": "./dist/index.js",
         "require": "./dist/index.js"
      }
   },
   "keywords": [
      "vexnor-plugin",
      "vexnor-mssql",
      "vexnor",
      "mssql",
      "sql",
      "plugin"
   ],
   "sideEffects": [
      "./dist/index.js",
      "./dist/index.browser.js",
      "./dist/vexnor-mssql.js",
      "./dist/mssql-augment.js"
   ],
   "publishConfig": {
      "access": "public"
   },
   "scripts": {
      "clean": "rimraf dist tsconfig.tsbuildinfo",
      "build": "tsc -b",
      "postbuild": "tsc-alias",
      "pretest": "run-s 'build'",
      "test": "vitest --coverage run",
      "test:watch": "vitest --watch",
      "test:run": "vitest run"
   },
   "files": [
      "dist",
      "package.json",
      "README.md"
   ],
   "dependencies": {
      "vexnor": "workspace:^"
   },
   "devDependencies": {
      "@types/mssql": "^12.3.0",
      "@vitest/coverage-v8": "^4.1.5",
      "npm-run-all": "^4.1.5",
      "tsc-alias": "^1.8.16",
      "typescript": "^5.9.3",
      "vite-tsconfig-paths": "^6.1.1",
      "vitest": "^4.1.5"
   },
   "peerDependencies": {
      "mssql": "^12.5.2"
   },
   "peerDependenciesMeta": {
      "mssql": {
         "optional": true
      }
   }
}

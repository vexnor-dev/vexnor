{
   "name": "vexnor-postgres",
   "version": "1.0.0-beta.1",
   "description": "PostgreSQL plugin for vexnor supporting pg and postgres.js drivers",
   "type": "module",
   "module": "dist/index.js",
   "main": "dist/index.js",
   "types": "dist/index.d.ts",
   "exports": {
      ".": {
         "types": "./dist/index.d.ts",
         "browser": "./dist/index.browser.js",
         "import": "./dist/index.js",
         "require": "./dist/index.js"
      }
   },
   "keywords": [
      "vexnor-plugin",
      "vexnor-postgres",
      "vexnor",
      "postgresql",
      "postgres",
      "pg",
      "postgres.js",
      "sql",
      "plugin"
   ],
   "author": "Adrian Topala",
   "license": "Apache-2.0",
   "repository": "https://github.com/vexnor-dev/vexnor",
   "sideEffects": [
      "./dist/vexnor-postgres.js"
   ],
   "publishConfig": {
      "access": "public"
   },
   "scripts": {
      "build": "run-s 'build:*'",
      "build:1-tsc": "tsc -b",
      "build:2-alias": "tsc-alias",
      "pretest": "run-s 'build'",
      "test": "vitest --coverage run",
      "test:watch": "vitest --watch",
      "test:run": "vitest run",
      "vexnor:exec": "pnpm vexnor exec run --config ../../vexnor.config.ts --query-config find-enums.vexnor.ts findEnums | pino-pretty"
   },
   "files": [
      "dist",
      "package.json",
      "README.md"
   ],
   "dependencies": {
      "vexnor": "workspace:^"
   },
   "devDependencies": {
      "@types/pg": "^8.15.5",
      "@vitest/coverage-v8": "^4.1.5",
      "npm-run-all": "^4.1.5",
      "tsc-alias": "^1.8.16",
      "typescript": "^5.9.3",
      "vite-tsconfig-paths": "^6.1.1",
      "vitest": "^4.1.5"
   },
   "peerDependencies": {
      "pg": "^8.16.3"
   },
   "peerDependenciesMeta": {
      "pg": {
         "optional": true
      }
   }
}

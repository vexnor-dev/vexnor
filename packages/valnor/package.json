{
   "name": "valnor",
   "version": "1.0.0-beta.1",
   "description": "",
   "type": "module",
   "main": "./dist/core/index.js",
   "types": "./dist/core/index.d.ts",
   "module": "./dist/core/index.js",
   "exports": {
      ".": {
         "import": "./dist/core/index.js",
         "types": "./dist/core/index.d.ts",
         "require": "./dist/core/index.js"
      },
      "./plugin": {
         "import": "./dist/plugin/index.js",
         "types": "./dist/plugin/index.d.ts",
         "require": "./dist/plugin/index.js"
      },
      "./config": {
         "import": "./dist/config/index.js",
         "types": "./dist/config/index.d.ts",
         "require": "./dist/config/index.js"
      },
      "./testing": {
         "import": "./dist/testing/index.js",
         "types": "./dist/testing/index.d.ts",
         "require": "./dist/testing/index.js"
      }
   },
   "keywords": [
      "valnor",
      "postgres",
      "sql",
      "postgres.js",
      "pg",
      "mssql",
      "mysql",
      "strongly typed sql",
      "query builder",
      "orm"
   ],
   "author": "Adrian Topala",
   "license": "Apache-2.0",
   "repository": "https://github.com/atopala/valnor",
   "publishConfig": {
      "access": "public"
   },
   "homepage": "https://github.com/atopala/valnor#readme",
   "bugs": {
      "url": "https://github.com/atopala/valnor/issues"
   },
   "bin": {
      "valnor": "./cli.mjs"
   },
   "engines": {
      "node": ">=18.0.0"
   },
   "scripts": {
      "clean": "rimraf dist tsconfig.tsbuildinfo",
      "build": "run-s 'build:*'",
      "build:1-tsc": "tsc -b",
      "prepack:1-copy-readme": "copyfiles -f \"../../README.md\" .",
      "prepack": "run-s 'build' 'prepack:*'",
      "pretest": "run-s 'build'",
      "test": "vitest --coverage run",
      "test:watch": "vitest --watch",
      "test:run": "vitest run"
   },
   "files": [
      "dist",
      "package.json",
      "README.md"
   ],
   "dependencies": {
      "code-block-writer": "^11.0.3",
      "commander": "^9.1.0",
      "glob": "^11.0.3",
      "pino": "^7.10.0",
      "to-case": "^2.0.0"
   },
   "devDependencies": {
      "@types/pg": "^8.15.5",
      "@vitest/coverage-v8": "^3.2.4",
      "vite-tsconfig-paths": "^5.1.4",
      "vitest": "^3.2.4"
   },
   "peerDependencies": {
      "mariadb": "^3.4.5",
      "mssql": "^11.0.1",
      "pg": "^8.16.3"
   },
   "peerDependenciesMeta": {
      "pg": {
         "optional": true
      },
      "mssql": {
         "optional": true
      },
      "mariadb": {
         "optional": true
      }
   }
}

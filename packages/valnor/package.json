{
   "name": "valnor",
   "version": "1.0.0-beta.1",
   "description": "",
   "type": "module",
   "module": "lib.mjs",
   "main": "lib.mjs",
   "types": "dist/lib/index.d.ts",
   "keywords": [
      "valnor",
      "postgres",
      "sql",
      "postgres.js",
      "pg",
      "mssql",
      "mysql",
      "strongly typed sql",
      "query builder",
      "orm"
   ],
   "author": "Adrian Topala",
   "license": "MIT",
   "repository": "https://github.com/atopala/pg-typecraft",
   "publishConfig": {
      "access": "public"
   },
   "homepage": "https://github.com/atopala/pg-typecraft#readme",
   "bugs": {
      "url": "https://github.com/atopala/pg-typecraft/issues"
   },
   "bin": {
      "valnor": "./cli.mjs"
   },
   "scripts": {
      "build": "run-s 'build:*'",
      "build:1-template-1": "copyfiles -f ./src/include/postgres-library.ts ./dist/@templates",
      "build:1-template-2": "copyfiles -f ./src/lib/types.ts ./dist/@templates",
      "build:2-tsc": "tsc -b",
      "prepack:1-copy-readme": "copyfiles -f \"../../README.md\" .",
      "prepack": "run-s 'build' 'prepack:*'",
      "test": "vitest run",
      "test:watch": "vitest --watch",
      "test:run": "vitest run"
   },
   "files": [
      "dist",
      "package.json",
      "README.md"
   ],
   "dependencies": {
      "code-block-writer": "^11.0.3",
      "commander": "^9.1.0",
      "pino": "^7.10.0",
      "to-case": "^2.0.0",
      "vitest": "^3.2.4"
   },
   "devDependencies": {
      "@types/pg": "^8.15.5",
      "vite": "^7.1.4"
   },
   "optionalDependencies": {
      "pg": "^8.16.3",
      "postgres": "^3.4.7"
   }
}

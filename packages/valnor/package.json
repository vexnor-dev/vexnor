{
   "name": "valnor",
   "version": "1.0.0-beta.1",
   "description": "",
   "type": "module",
   "main": "./dist/core/index.js",
   "types": "./dist/core/index.d.ts",
   "module": "./dist/core/index.js",
   "exports": {
      ".": {
         "import": "./dist/core/core.js",
         "types": "./dist/core/core.d.ts",
         "require": "./dist/core/core.js"
      },
      "./plugin": {
         "import": "./dist/plugin/plugin.js",
         "types": "./dist/plugin/plugin.d.ts",
         "require": "./dist/plugin/plugin.js"
      },
      "./config": {
         "import": "./dist/config/config.js",
         "types": "./dist/config/config.d.ts",
         "require": "./dist/config/config.js"
      },
      "./testing": {
         "import": "./dist/test/testing.js",
         "types": "./dist/test/testing.d.ts",
         "require": "./dist/test/testing.js"
      }
   },
   "keywords": [
      "valnor",
      "postgres",
      "sql",
      "postgres.js",
      "pg",
      "mssql",
      "mysql",
      "strongly typed sql",
      "query builder",
      "orm"
   ],
   "author": "Adrian Topala",
   "license": "Apache-2.0",
   "repository": "https://github.com/atopala/valnor",
   "publishConfig": {
      "access": "public"
   },
   "homepage": "https://github.com/atopala/valnor#readme",
   "bugs": {
      "url": "https://github.com/atopala/valnor/issues"
   },
   "bin": {
      "valnor": "./cli.mjs"
   },
   "engines": {
      "node": ">=22.21.1"
   },
   "scripts": {
      "clean": "rimraf dist tsconfig.tsbuildinfo",
      "build": "run-s 'build:*'",
      "build:1-tsc": "tsc -b",
      "build:2-alias": "tsc-alias",
      "prepack:1-copy-readme": "copyfiles -f \"../../README.md\" .",
      "prepack": "run-s 'build' 'prepack:*'",
      "pretest": "run-s 'build'",
      "test": "vitest --coverage run",
      "test:watch": "vitest --watch",
      "test:run": "vitest run"
   },
   "files": [
      "dist",
      "package.json",
      "README.md"
   ],
   "dependencies": {
      "code-block-writer": "^11.0.3",
      "commander": "^9.1.0",
      "glob": "11.1.0",
      "pino": "^7.10.0",
      "sql-formatter": "^15.7.0",
      "to-case": "^2.0.0",
      "tsx": "^4.20.6"
   },
   "devDependencies": {
      "@types/pg": "^8.15.5",
      "@vitest/coverage-v8": "^4.1.5",
      "tsc-alias": "^1.8.16",
      "vite-tsconfig-paths": "^6.1.1",
      "vitest": "^4.1.5"
   }
}

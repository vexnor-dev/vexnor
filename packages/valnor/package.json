{
   "name": "valnor",
   "version": "1.0.0-beta.1",
   "description": "",
   "type": "module",
   "module": "dist/lib/index.js",
   "main": "dist/lib/index.js",
   "types": "dist/lib/index.d.ts",
   "exports": {
      ".": "./dist/core/index.js",
      "./core": "./dist/core/index.js",
      "./plugin": "./dist/plugin/index.js"
   },
   "keywords": [
      "valnor",
      "postgres",
      "sql",
      "postgres.js",
      "pg",
      "mssql",
      "mysql",
      "strongly typed sql",
      "query builder",
      "orm"
   ],
   "author": "Adrian Topala",
   "license": "Apache-2.0",
   "repository": "https://github.com/atopala/valnor",
   "publishConfig": {
      "access": "public"
   },
   "homepage": "https://github.com/atopala/valnor#readme",
   "bugs": {
      "url": "https://github.com/atopala/valnor/issues"
   },
   "bin": {
      "valnor": "./cli.mjs"
   },
   "engines": {
      "node": ">=18.0.0"
   },
   "scripts": {
      "build": "run-s 'build:*'",
      "build:1-template-1": "copyfiles -f ./src/include/postgres-library.ts ./dist/@templates",
      "build:1-template-2": "copyfiles -f src/core/types.ts ./dist/@templates",
      "build:2-tsc": "tsc -b",
      "prepack:1-copy-readme": "copyfiles -f \"../../README.md\" .",
      "prepack": "run-s 'build' 'prepack:*'",
      "pretest": "run-s 'build'",
      "test": "vitest --coverage run",
      "test:watch": "vitest --watch",
      "test:run": "vitest run"
   },
   "files": [
      "dist",
      "package.json",
      "README.md"
   ],
   "dependencies": {
      "code-block-writer": "^11.0.3",
      "commander": "^9.1.0",
      "pino": "^7.10.0",
      "to-case": "^2.0.0"
   },
   "devDependencies": {
      "@types/pg": "^8.15.5",
      "@vitest/coverage-v8": "^3.2.4",
      "postgres": "^3.4.7",
      "vite": "^7.1.4",
      "vitest": "^3.2.4"
   },
   "peerDependencies": {
      "mariadb": "^3.4.5",
      "mssql": "^11.0.1",
      "pg": "^8.16.3",
      "postgres": "^3.4.7"
   },
   "peerDependenciesMeta": {
      "pg": {
         "optional": true
      },
      "mssql": {
         "optional": true
      },
      "mariadb": {
         "optional": true
      }
   }
}

{
   "name": "valnor-typeorm",
   "version": "1.0.0-beta.1",
   "description": "TypeORM adaptor for valnor — convert TypeORM entities to valnor runtime tables",
   "type": "module",
   "module": "dist/index.js",
   "main": "dist/index.js",
   "types": "dist/index.d.ts",
   "exports": {
      ".": {
         "types": "./dist/index.d.ts",
         "import": "./dist/index.js",
         "require": "./dist/index.js"
      }
   },
   "keywords": [
      "valnor",
      "typeorm",
      "adaptor",
      "sql"
   ],
   "author": "Adrian Topala",
   "license": "Apache-2.0",
   "repository": "https://github.com/atopala/valnor",
   "publishConfig": {
      "access": "public"
   },
   "scripts": {
      "build": "run-s 'build:*'",
      "build:1-tsc": "tsc -b",
      "build:2-alias": "tsc-alias",
      "pretest": "run-s 'build'",
      "test": "vitest --coverage run",
      "test:watch": "vitest --watch",
      "test:run": "vitest run"
   },
   "files": [
      "dist",
      "package.json",
      "README.md"
   ],
   "dependencies": {
      "valnor": "workspace:^"
   },
   "devDependencies": {
      "typeorm": "^0.3.24",
      "better-sqlite3": "^12.4.1",
      "reflect-metadata": "^0.2.2",
      "@types/better-sqlite3": "^7.6.13",
      "@vitest/coverage-v8": "^4.0.18",
      "npm-run-all": "^4.1.5",
      "tsc-alias": "^1.8.16",
      "typescript": "^5.9.3",
      "vite-tsconfig-paths": "^6.1.1",
      "vitest": "^4.0.18"
   },
   "peerDependencies": {
      "typeorm": ">=0.3.0",
      "reflect-metadata": ">=0.1.0"
   }
}

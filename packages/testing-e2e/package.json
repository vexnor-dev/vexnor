{
   "name": "testing-e2e",
   "version": "1.0.0",
   "description": "e2e scenario testing with cucumber.js",
   "type": "module",
   "scripts": {
      "codegen": "run-s 'codegen:*'",
      "codegen:1-generate": "env-cmd --no-override -x -r ../../env-dev.json -e db valnor generate --driver pg --schema one_sql --pascalCaseTables --camelCaseColumns --host \\$POSTGRES_HOST --port \\$POSTGRES_PORT --database \\$POSTGRES_DATABASE --user \\$POSTGRES_USER --password \\$POSTGRES_PASSWORD --outDir 'src/codegen' | pino-pretty",
      "postcodegen": "pnpx eslint --config ../../eslint.config.mjs ./src/codegen/**/*.ts --fix",
      "prebuild": "run-s 'codegen'",
      "build": "tsc -b",
      "pretest": "run-s 'build'",
      "test": "env-cmd --no-override -x -r ../../env-dev.json -e db cucumber-js --publish | pino-pretty"
   },
   "keywords": [],
   "author": "",
   "license": "ISC",
   "dependencies": {
      "@cucumber/cucumber": "^11.3.0",
      "@sinclair/typebox": "^0.34.36",
      "pg": "^8.16.3",
      "valnor": "workspace:^1.0.0",
      "valnor-postgres": "workspace:^1.0.0"
   },
   "devDependencies": {
      "@cucumber/pretty-formatter": "^1.0.1",
      "@types/pg": "^8.15.5",
      "copyfiles": "^2.4.1",
      "cucumber-html-reporter": "latest",
      "ts-node": "^10.9.2"
   }
}

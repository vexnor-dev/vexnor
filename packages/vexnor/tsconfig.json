{
   "extends": "../../tsconfig.json",
   "compilerOptions": {
      "ignoreDeprecations": "5.0",
      "rootDir": "src",
      "outDir": "./dist",
      "declaration": true,
      "declarationMap": true,
      "target": "ESNext",
      "lib": ["ESNext"],
      "composite": true,
      "baseUrl": ".",
      "paths": {
         "@test-models/*": ["./src/test/models/*"],
         "#/*": ["./src/*"]
      }
   },
   "include": ["src/**/*"]
}
